# ==========================
# Import Libraries
# ==========================

import pandas as pd
import numpy as np

print("="*60)
print("SMART RETAIL ANALYTICS - DATA CLEANING")
print("="*60)


# ==========================
# Load Datasets
# ==========================

customers = pd.read_csv("../Dataset/customers.csv")
orders = pd.read_csv("../Dataset/orders.csv")
products = pd.read_csv("../Dataset/products.csv")
inventory = pd.read_csv("../Dataset/inventory.csv")
sales_targets = pd.read_csv("../Dataset/sales_targets.csv")

print("\nDatasets Loaded Successfully.\n")


# ==========================
# Store all datasets
# ==========================

datasets = {
    "Customers": customers,
    "Orders": orders,
    "Products": products,
    "Inventory": inventory,
    "Sales Targets": sales_targets
}


# ==========================
# Dataset Overview
# ==========================

for name, df in datasets.items():

    print("\n" + "="*60)
    print(name.upper())
    print("="*60)

    print("\nFirst Five Records\n")
    print(df.head())

    print("\nShape")
    print(df.shape)

    print("\nColumn Names")
    print(df.columns.tolist())

    print("\nData Types")
    print(df.dtypes)

    print("\nInformation")
    print(df.info())


# ==========================
# Missing Values
# ==========================

print("\n")
print("="*60)
print("MISSING VALUES")
print("="*60)

for name, df in datasets.items():

    print("\n",name)
    print(df.isnull().sum())


# ==========================
# Duplicate Records
# ==========================

print("\n")
print("="*60)
print("DUPLICATE RECORDS")
print("="*60)

for name, df in datasets.items():

    print("\n",name)
    print("Duplicate Rows :",df.duplicated().sum())


# ==========================
# Remove Duplicate Records
# ==========================

customers.drop_duplicates(inplace=True)
orders.drop_duplicates(inplace=True)
products.drop_duplicates(inplace=True)
inventory.drop_duplicates(inplace=True)
sales_targets.drop_duplicates(inplace=True)

print("\nDuplicates Removed Successfully.")


# ==========================
# Convert Data Types
# ==========================

orders["Date"] = pd.to_datetime(orders["Date"])

print("\nDate Converted Successfully.")


# ==========================
# Feature Engineering
# ==========================

orders["Year"] = orders["Date"].dt.year
orders["Month"] = orders["Date"].dt.month
orders["Month_Name"] = orders["Date"].dt.month_name()
orders["Quarter"] = orders["Date"].dt.quarter
orders["Week"] = orders["Date"].dt.isocalendar().week

print("\nFeature Engineering Completed.")


# ==========================
# Check Cleaned Data
# ==========================

print("\n")
print("="*60)
print("ORDERS DATASET")
print("="*60)

print(orders.head())


# ==========================
# Statistical Summary
# ==========================

print("\n")
print("="*60)
print("STATISTICAL SUMMARY")
print("="*60)

for name, df in datasets.items():

    print("\n",name)

    print(df.describe(include="all"))


# ==========================
# Save Cleaned Files
# ==========================

customers.to_csv("../Dataset/customers_cleaned.csv",index=False)

orders.to_csv("../Dataset/orders_cleaned.csv",index=False)

products.to_csv("../Dataset/products_cleaned.csv",index=False)

inventory.to_csv("../Dataset/inventory_cleaned.csv",index=False)

sales_targets.to_csv("../Dataset/sales_targets_cleaned.csv",index=False)


# ==========================
# Final Dataset Shapes
# ==========================

print("\n")
print("="*60)
print("FINAL DATASET SHAPES")
print("="*60)

print("Customers :",customers.shape)
print("Orders :",orders.shape)
print("Products :",products.shape)
print("Inventory :",inventory.shape)
print("Sales Targets :",sales_targets.shape)


# ==========================
# Data Quality Report
# ==========================

print("\n")
print("="*60)
print("DATA QUALITY REPORT")
print("="*60)

for name, df in datasets.items():

    print("\nDataset :",name)

    print("Rows :",df.shape[0])

    print("Columns :",df.shape[1])

    print("Missing Values :",df.isnull().sum().sum())

    print("Duplicate Rows :",df.duplicated().sum())


print("\n")
print("="*60)
print("DATA CLEANING COMPLETED SUCCESSFULLY")
print("="*60)
